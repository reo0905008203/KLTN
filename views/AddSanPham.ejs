<!DOCTYPE html>
<html>
<head>
    <meta charset='utf-8'>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'>
    <title>Thêm sản phẩm - PC Shop</title>
    <meta name='viewport' content='width=device-width, initial-scale=1'>
    <link rel="stylesheet" href="/styles/style.css">
</head>
<body>
    <div class="lr">
        <form action="/admin/AddSP" method="POST" enctype="multipart/form-data" class="l-form">
            <h2>Thêm Sản Phẩm</h2>
            <label for="Ma_SP">Mã sản phẩm</label>
            <input type="text" name="Ma_SP" required maxlength="10">

            <label for="Ten_SP">Tên sản phẩm</label>
            <input type="text" name="Ten_SP" required>

            <label for="Mo_Ta">Mô tả</label>
            <textarea name="Mo_Ta" rows="4" required style="width: 100%; padding: 10px; border: 2px solid #e0e0e0; border-radius: 5px;"></textarea>

            <label for="Danh_Muc">Danh Mục</label>
            <select name="Danh_Muc" id="Danh_Muc" style="width: 100%; padding: 10px; border: 2px solid #e0e0e0; border-radius: 5px; margin-bottom: 15px;">
                <% Catas.forEach(cata => { %>
                    <option value="<%= cata.Cata_id %>"><%= cata.Ten_Cata %></option>
                <% }) %>
            </select>

            <label for="Gia">Giá</label>
            <input type="number" name="Gia" required min="0" step="0.01">

            <label for="So_Luong">Số lượng</label>
            <input type="number" name="So_Luong" required min="0">

            <label for="Hinh_Anh">Hình ảnh</label>
            <input type="file" name="Hinh_Anh" accept="image/*" required style="margin-bottom: 15px;">

            <button type="submit">Thêm sản phẩm</button>
            
            <a href="/admin/Quanlysanpham">Trở lại</a>
        </form>
    </div>
</body>
</html>
