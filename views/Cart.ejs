<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Giỏ hàng - PC Shop</title>
    <link rel="stylesheet" href="/styles/style.css">
</head>

<header>
    <div class="logo">
        <a href="/"><h1>PC Shop</h1></a>
    </div>
    <nav>
        <a href="/">Trang chủ</a>
        <a href="/products">Sản phẩm</a>
        <a href="/orders">Đơn hàng</a>
        <a href="/Cart">Giỏ hàng</a>
        <a href="/logout">Đăng xuất</a>
    </nav>
</header>

<body>
    <div class="cart-container">
        <h2>Giỏ hàng của bạn</h2>
        <% if (cartItems.length > 0) { %>
            <table class="cart-table">
                <thead>
                    <tr>
                        <th>Ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Giá</th>
                        <th>Số lượng</th>
                        <th>Thành tiền</th>
                        <th>Xóa</th>
                    </tr>
                </thead>
                <tbody>
                    <% cartItems.forEach(item => { %>
                        <tr>
                            <td><img src="<%= item.Anh_SP || '/uploads/default-pc.jpg' %>" alt="<%= item.Ten_Product %>" width="80"></td>
                            <td><%= item.Ten_Product %></td>
                            <td><%= item.Gia.toLocaleString() %>₫</td>
                            <td>    
                                <form action="/Products/cart/update/<%= item.Cart_id %>" method="POST" class="quantity-form">
                                    <button type="submit" name="action" value="decrease">-</button>
                                    <span><%= item.So_Luong %></span>
                                    <button type="submit" name="action" value="increase">+</button>
                                </form>
                            </td>
                            <td><%= (item.Gia * item.So_Luong).toLocaleString() %>₫</td>
                            <td><a href="/Products/cart/del/<%= item.Cart_id %>" class="action-button">Xóa</a></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
            <h3 class="cart-total">Tổng tiền: <%= total.toLocaleString() %>₫</h3>
            <a href="/checkout" class="btn-checkout">Đặt hàng</a>
        <% } else { %>
            <p class="cart-empty-message">Giỏ hàng của bạn đang trống.</p>
        <% } %>
    </div>
</body>

<% if (typeof user !== 'undefined' && user) { %>
    <link rel="stylesheet" href="/styles/chatbox.css">
    <div data-user-id="<%= user.User_id.trim() %>" data-is-admin="<%= user.Quyen_han ? 'true' : 'false' %>" style="display: none;"></div>
    <script src="/js/chatbox.js"></script>
<% } %>

</html>
