<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.Ten_Product %> - PC Shop</title>
    <link rel="stylesheet" href="/styles/style.css">
</head>

<header>
    <div class="logo">
        <a href="/"><h1>PC Shop</h1></a>
    </div>
    <nav>
        <form action="/search" method="get" class="search-form">
            <input type="text" name="keyword" placeholder="Tìm sản phẩm..." required>
            <button type="submit">Tìm</button>
        </form>
        <a href="/">Trang chủ</a>
        <a href="/products">Sản phẩm</a>
        <a href="/orders">Đơn hàng</a>
        <a href="/Cart">Giỏ hàng</a>
        <a href="/logout">Đăng xuất</a>
    </nav>
</header>

<body>
    <div class="detail-container">
        <div class="detail-image">
            <img src="<%= product.Anh_SP || '/uploads/default-pc.jpg' %>" alt="<%= product.Ten_Product %>">
        </div>
        <div class="detail-info">
            <h2><%= product.Ten_Product %></h2>
            <p><strong>Mô tả:</strong> <%= product.Mo_Ta_Product %></p>
            <p><strong>Danh mục:</strong> <%= product.Ten_Cata || '' %></p>
            <p class="price"><%= product.Gia.toLocaleString() %> VND</p>
            <% if (product.So_Luong > 0 ) { %>
                <p><strong>Số lượng còn lại:</strong> <%= product.So_Luong %></p>
            <% } %>
            <form action="/Products/cart/add" method="POST">
                <input type="hidden" name="Product_id" value="<%= product.Product_id %>">
                
                <% if (product.So_Luong > 0) { %>
                    <label for="So_Luong"><strong>Số lượng:</strong></label>
                    <input 
                        type="number" 
                        name="So_Luong" 
                        min="1" 
                        max="<%= product.So_Luong %>" 
                        value="1" 
                        required
                    >
                    <button class="btn-add" type="submit">Thêm vào giỏ hàng</button>
                <% } else { %>
                    <p><strong>Hết hàng</strong></p>
                <% } %>
            </form>
        </div>
    </div>
    <div class="comments-section">
        <h3>Bình luận</h3>
    
        <% if (comments && comments.length > 0) { %>
            <ul>
                <% comments.forEach(comment => { %>
                    <li><strong><%= comment.Ho_Ten_User %>:</strong> <%= comment.Noi_dung %></li>
                <% }) %>
            </ul>
        <% } else { %>
            <p>Chưa có bình luận nào.</p>
        <% } %>
    
        <form action="/Products/<%= product.Product_id %>/comment" method="POST">
            <textarea name="Noi_dung" rows="4" cols="50" placeholder="Viết bình luận..." required></textarea>
            <br>
            <button type="submit" class="btn-add">Gửi bình luận</button>
        </form>
    </div>
    <h2>Sản phẩm liên quan</h2>
    <div class="related-products">
        <% relatedProducts.forEach(rp => { %>
            <div class="related-item">
                <a href="/Products/<%= rp.Product_id %>">
                    <img src="<%= rp.Anh_SP || '/uploads/default-pc.jpg' %>" alt="<%= rp.Ten_Product %>">
                    <h4><%= rp.Ten_Product %></h4>
                    <p><%= rp.Gia.toLocaleString() %> VND</p>
                </a>
            </div>
        <% }) %>
    </div>
</body>

<footer>
    <div class="logo">
        <a href="/"><h2>PC Shop</h2></a>
    </div>
    <div class="info">
        <p>Địa chỉ: Đà Nẵng, Việt Nam</p>
        <p>SĐT: 0123456789</p>
        <p>Email: support@pcshop.com</p>
    </div>
    <div class="req">
        <p><a href="#">Chính sách mua hàng</a> </p>
        <p><a href="#">Hỗ trợ</a></p>
    </div>
</footer>

<% if (typeof user !== 'undefined' && user) { %>
    <link rel="stylesheet" href="/styles/chatbox.css">
    <div data-user-id="<%= user.User_id.trim() %>" data-is-admin="<%= user.Quyen_han ? 'true' : 'false' %>" style="display: none;"></div>
    <script src="/js/chatbox.js"></script>
<% } %>

</html>
