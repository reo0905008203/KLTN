<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đơn hàng của tôi - PC Shop</title>
    <link rel="stylesheet" href="/styles/style.css">
</head>

<header>
    <div class="logo">
        <a href="/"><h1>PC Shop</h1></a>
    </div>
    <nav>
        <a href="/">Trang chủ</a>
        <a href="/products">Sản phẩm</a>
        <a href="/orders">Đơn hàng</a>
        <a href="/Cart">Giỏ hàng</a>
        <a href="/logout">Đăng xuất</a>
    </nav>
</header>

<body>
    <div class="Orders-container">
        <h2>Đơn hàng của bạn</h2>

        <% if (orders.length > 0) { %>
            <% let currentOrder = null; %>
            <% orders.forEach(order => { %>
                <% if (currentOrder !== order.Order_id) { %>
                    <% if (currentOrder !== null) { %></table><hr><% } %>
                    <h3>Đơn hàng #<%= order.Order_id %> -
                        <%= new Date(order.Ngay_Dat).toLocaleString() %> - 
                        Trạng thái: <%= order.Trang_Thai %>
                        <% if (order.Trang_Thai === 'Chờ xử lý') { %>
                            | <a href="/orders/cancel/<%= order.Order_id %>" onclick="return confirm('Bạn có chắc muốn hủy đơn hàng này không?')">Hủy đơn</a>
                        <% } %>
                    </h3>
                    <table>
                        <thead>
                            <tr>
                                <th>Ảnh</th>
                                <th>Tên sản phẩm</th>
                                <th>Số lượng</th>
                                <th>Giá</th>
                            </tr>
                        </thead>
                        <tbody>
                <% currentOrder = order.Order_id; } %>
                    <tr>
                        <td><img src="<%= order.Anh_SP || '/uploads/default-pc.jpg' %>" width="80"></td>
                        <td><%= order.Ten_Product %></td>
                        <td><%= order.So_Luong %></td>
                        <td><%= (order.Gia * order.So_Luong).toLocaleString() %>₫</td>
                    </tr>
            <% }) %>
            </tbody></table>
        <% } else { %>
            <p class="cart-empty-message">Bạn chưa có đơn hàng nào.</p>
        <% } %>
    </div>
</body>

<% if (typeof user !== 'undefined' && user) { %>
    <link rel="stylesheet" href="/styles/chatbox.css">
    <div data-user-id="<%= user.User_id.trim() %>" data-is-admin="<%= user.Quyen_han ? 'true' : 'false' %>" style="display: none;"></div>
    <script src="/js/chatbox.js"></script>
<% } %>

</html>
