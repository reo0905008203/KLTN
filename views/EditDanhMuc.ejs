<!DOCTYPE html>
<html>
<head>
    <meta charset='utf-8'>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'>
    <title>Sửa danh mục - PC Shop</title>
    <meta name='viewport' content='width=device-width, initial-scale=1'>
    <link rel="stylesheet" href="/styles/style.css">
</head>
<body>
    <div class="lr">
        <form action="/admin/EditDM" method="POST" class="l-form">
            <h2>Sửa Danh Mục</h2>
            <input type="hidden" name="Cataid" value="<%= Cata.Cata_id %>">
            
            <label for="TenDanhMuc">Tên danh mục</label>
            <input type="text" name="TenDanhMuc" value="<%= Cata.Ten_Cata %>" required>

            <button type="submit">Cập nhật</button>
            
            <a href="/admin/Quanlydanhmuc">Trở lại</a>
        </form>
    </div>
</body>
</html>
